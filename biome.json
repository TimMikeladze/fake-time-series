{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/storybook-static",
			"!**/coverage",
			"!**/.next",
			"!**/node_modules"
		]
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noDefaultExport": "off",
				"useFilenamingConvention": "off",
				"useNamingConvention": {
					"level": "error",
					"options": {
						"strictCase": false
					}
				}
			},
			"suspicious": {
				"noReactSpecificProps": "off",
				"noConsole": {
					"level": "warn",
					"fix": "none"
				}
			},
			"correctness": {
				"useImportExtensions": "off",
				"noUndeclaredDependencies": "off",
				"noUnusedVariables": "off",
				"noNodejsModules": "off"
			}
		}
	}
}
